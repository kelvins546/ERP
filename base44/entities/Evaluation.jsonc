{
  "name": "Evaluation",
  "type": "object",
  "properties": {
    "employee_id": {
      "type": "string",
      "title": "Employee ID"
    },
    "employee_name": {
      "type": "string",
      "title": "Employee"
    },
    "evaluator_id": {
      "type": "string",
      "title": "Evaluator ID"
    },
    "evaluator_name": {
      "type": "string",
      "title": "Evaluator"
    },
    "period_start": {
      "type": "string",
      "format": "date",
      "title": "Period Start"
    },
    "period_end": {
      "type": "string",
      "format": "date",
      "title": "Period End"
    },
    "total_score": {
      "type": "number",
      "title": "Total Score"
    },
    "rating": {
      "type": "string",
      "enum": [
        "Needs Improvement",
        "Meets Expectations",
        "Exceeds Expectations",
        "Outstanding"
      ],
      "title": "Rating"
    },
    "feedback": {
      "type": "string",
      "title": "Feedback"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "submitted",
        "acknowledged"
      ],
      "title": "Status"
    }
  },
  "required": [
    "employee_id",
    "evaluator_id",
    "period_start",
    "period_end"
  ]
}